MONGO_URI=mongodb://127.0.0.1:27017/auth
PORT=3000
JWT_SECRET_KEY=replace-with-long-random-secret
JWT_REFRESH_SECRET=replace-with-different-long-random-secret
REDIS_URL=redis://127.0.0.1:6379
JWT_EXPIRES_IN_SECONDS=1800
CLIENT_URL=http://localhost:5173
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=example_user
EMAIL_PASS=example_pass
EMAIL_FROM="Auth System <no-reply@example.com>"
EMAIL_CONNECTION_TIMEOUT=10000
EMAIL_GREETING_TIMEOUT=10000
EMAIL_SOCKET_TIMEOUT=15000
NODE_ENV=development
